--- a/dist/do-rpc/client.js
+++ b/dist/do-rpc/client.js
@@ -6,28 +6,48 @@ import { Effect, Fiber, FiberMap, Layer, RpcClient, RpcSerialization, } from '@l
 const processReadableStream = (stream, parser, writeResponse) => Effect.gen(function* () {
     const reader = stream.getReader();
     yield* Effect.gen(function* () {
+        // Drain the full stream into one buffer BEFORE decoding.
+        //
+        // Why: with msgpackr's `useRecords: true`, the parser greedily reads N
+        // record-references for an array(N) header even when the buffer is
+        // truncated mid-record. It returns a "successful" but garbage decode
+        // instead of throwing `incomplete`. If we then try to writeResponse the
+        // garbage, schema validation throws, which aborts this loop before any
+        // remaining stream chunks get read — so we permanently lose the rest of
+        // the stream's bytes. Draining first guarantees the decoder always sees
+        // a complete buffer.
+        const chunks = [];
+        let totalBytes = 0;
         while (true) {
             const { done, value } = yield* Effect.tryPromise(() => reader.read()).pipe(Effect.orDie);
             if (done === true) {
                 break;
             }
-            // Decode the chunk
-            const decoded = parser.decode(value);
-            // Handle array of messages from server.
-            // Server sends `parser.encode([message])` per enqueue, so each decoded value is `[message]`.
-            // When CF DO RPC merges enqueues in production, we get `[[msg1], [msg2], ...]`.
-            // `flat(1)` normalizes both single and merged cases to `[msg1, msg2, ...]`.
-            let messages;
-            if (Array.isArray(decoded) === true) {
-                messages = decoded.flat(1);
-            }
-            else {
-                messages = [decoded];
-            }
-            // Write each message
-            for (const message of messages) {
-                yield* writeResponse(message);
-            }
+            chunks.push(value);
+            totalBytes += value.byteLength;
+        }
+        const combined = new Uint8Array(totalBytes);
+        let off = 0;
+        for (const c of chunks) {
+            combined.set(c, off);
+            off += c.byteLength;
+        }
+        // Decode the full buffer
+        const decoded = parser.decode(combined);
+        // Handle array of messages from server.
+        // Server sends `parser.encode([message])` per enqueue, so each decoded value is `[message]`.
+        // When CF DO RPC merges enqueues in production, we get `[[msg1], [msg2], ...]`.
+        // `flat(1)` normalizes both single and merged cases to `[msg1, msg2, ...]`.
+        let messages;
+        if (Array.isArray(decoded) === true) {
+            messages = decoded.flat(1);
+        }
+        else {
+            messages = [decoded];
+        }
+        // Write each message
+        for (const message of messages) {
+            yield* writeResponse(message);
         }
     }).pipe(Effect.withSpan('do-rpc-client:processReadableStream'), Effect.ensuring(Effect.promise(() => reader.cancel()).pipe(Effect.andThen(() => Effect.sync(() => reader.releaseLock())))));
 });
