{
  "name": "@cloudstash/extension",
  "version": "0.1.1",
  "private": true,
  "description": "Cloudstash Chrome extension — popup to quick-save links, syncing via Livestore",
  "author": "Bohdan Ptyts",
  "type": "module",
  "scripts": {
    "dev": "WXT_APP_URL=${WXT_APP_URL:-http://127.0.0.1:3000} wxt",
    "build": "wxt build",
    "build:local": "WXT_APP_URL=http://127.0.0.1:3000 wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test": "bun test",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@livestore/adapter-web": "0.0.0-snapshot-6e9abadf4bdc91a2f7deea3e47be8ffd75d4c27c",
    "@livestore/livestore": "0.0.0-snapshot-6e9abadf4bdc91a2f7deea3e47be8ffd75d4c27c",
    "@livestore/peer-deps": "0.0.0-snapshot-6e9abadf4bdc91a2f7deea3e47be8ffd75d4c27c",
    "@livestore/react": "0.0.0-snapshot-6e9abadf4bdc91a2f7deea3e47be8ffd75d4c27c",
    "@livestore/sync-cf": "0.0.0-snapshot-6e9abadf4bdc91a2f7deea3e47be8ffd75d4c27c",
    "@tailwindcss/vite": "4.2.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "effect": "3.21.2",
    "lucide-react": "0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "4.1.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@wxt-dev/module-react": "^1.1.3",
    "typescript": "^5.7.0",
    "wxt": "^0.20.0"
  }
}
