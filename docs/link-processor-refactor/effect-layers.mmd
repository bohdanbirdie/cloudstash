flowchart TB
    subgraph PL["processLink()"]
        direction TB
        P["Effect.gen function*<br/>yield* MetadataFetcher<br/>yield* ContentExtractor<br/>yield* AiSummaryGenerator<br/>yield* LinkEventStore"]
    end

    subgraph Live["Live Layers (production)"]
        direction TB
        ML["MetadataFetcherLive<br/>fetch() + HTMLRewriter<br/>timeout: 10s, retry: 2x"]
        CL["ContentExtractorLive<br/>fetch() + htmlparser2<br/>timeout: 15s, retry: 2x"]
        AL["AiSummaryGeneratorLive<br/>Layer.effect → yield* WorkersAi<br/>timeout: 30s"]
        SL["LinkEventStoreLive(store)<br/>store.commit()<br/>store.query()"]
        WA["WorkersAiLive(env.AI)<br/>Layer.succeed(WorkersAi, ai)"]
        WA -->|"provides WorkersAi"| AL
    end

    subgraph Test["Test Layers (vitest)"]
        direction TB
        MT["Layer.succeed(MetadataFetcher)<br/>returns configurable fixture"]
        CT["Layer.succeed(ContentExtractor)<br/>returns configurable fixture"]
        AT["Layer.succeed(AiSummaryGenerator)<br/>returns configurable fixture"]
        ST["createTestStore()<br/>records committed events[]"]
    end

    PL -->|"Effect.provide(liveLayer)"| Live
    PL -->|"Effect.provide(testLayer)"| Test

    DO["durable-object.ts<br/>Layer.mergeAll(<br/>  MetadataFetcherLive,<br/>  ContentExtractorLive,<br/>  AiSummaryGeneratorLive,<br/>  LinkEventStoreLive(store)<br/>).pipe(Layer.provide(<br/>  WorkersAiLive(env.AI)<br/>))"] --> Live

    UT["process-link.test.ts<br/>Layer.mergeAll(...)"] --> Test

