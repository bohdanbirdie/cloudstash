flowchart TB
    subgraph Path1["PATH 1: BROWSER (direct commit)"]
        Browser["Browser<br/>(synced LiveStore client)"]
        Reprocess["Reprocess<br/>button"]
    end

    subgraph Path2["PATH 2: EXTERNAL (queue)"]
        Telegram["Telegram<br/>webhook"]
        API["API / Raycast"]
    end

    Browser -->|"store.commit(linkCreated)<br/>source: app"| SyncDO
    Reprocess -->|"store.commit(linkProcessingStarted)"| SyncDO

    Telegram -->|"validate API key"| Worker
    API -->|"validate API key"| Worker

    SyncDO["SyncBackendDO"]
    Worker["Hono Worker<br/>return 200 immediately"]

    SyncDO -->|"onPush: detects linkCreated<br/>fire-and-forget fetch<br/>(wake up DO)"| LinkDO

    Worker -->|"env.LINK_QUEUE.send({<br/>url, orgId, source, sourceMeta<br/>})"| Queue

    subgraph Queue["Cloudflare Queue"]
        direction TB
        QMsg["LinkQueueMessage<br/>{ url, orgId, source, sourceMeta }"]
        QRetry["Retry: infra failures only<br/>max_retries: 3"]
        QDLQ["DLQ: link-processing-dlq"]
        QMsg --- QRetry --- QDLQ
    end

    Queue -->|"queue() handler<br/>max_concurrency=1<br/>(wakes up DO directly)"| LinkDO

    subgraph LinkDO["LinkProcessorDO (per org)"]
        direction TB

        LS["LiveStore Client<br/>(in-memory wasm SQLite)<br/>livePull → rematerialize"]

        subgraph Boot["On wake"]
            direction LR
            Sync["1. sync store"]
            Startup["2. startup sweep:<br/>cancel stale links"]
        end

        subgraph QueuePath["Queue path only"]
            direction LR
            Dedup["dedup check<br/>(query by URL)"]
            Commit["commit linkCreated<br/>(with source + sourceMeta)"]
            Dedup --> Commit
        end

        subgraph Processing["processLink() — both paths"]
            direction LR
            MF["MetadataFetcher<br/>10s timeout, 2x retry"]
            CE["ContentExtractor<br/>15s timeout, 2x retry"]
            AI["AiSummaryGenerator<br/>30s timeout"]
            LS2["LinkEventStore<br/>commit results"]
            MF --> CE --> AI --> LS2
        end

        subgraph Notify["processingStatus$ subscription"]
            direction LR
            NS["notifySource()"]
            TG["telegram → 👍/👎"]
            App["app → noop (sync)"]
            ApiN["api → noop"]
            NS --> TG
            NS --> App
            NS --> ApiN
        end

        LS --> Boot
        Boot --> QueuePath
        Boot --> Processing
        Processing --> Notify
    end

    LS -->|"store.commit() → push via RPC"| SyncDO
    SyncDO -->|"broadcast"| Clients["All Clients<br/>(browser sees results via sync)"]

    style Path1 fill:#e8f5e9,stroke:#388e3c
    style Path2 fill:#e3f2fd,stroke:#1976d2
    style Queue fill:#e3f2fd,stroke:#1976d2
    style Processing fill:#e8f5e9,stroke:#388e3c
    style Notify fill:#fff3e0,stroke:#f57c00
    style LinkDO fill:#fafafa,stroke:#666
