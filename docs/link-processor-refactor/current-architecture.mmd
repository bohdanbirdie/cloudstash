flowchart TB
    subgraph Ingestion
        Browser["Browser<br/>(LiveStore sync)"]
        Telegram["Telegram<br/>webhook"]
        API["API / Raycast<br/>/api/ingest"]
        Reprocess["Reprocess<br/>button"]
    end

    Browser -->|"v1.LinkCreated event"| SyncDO
    Telegram -->|"POST /api/telegram"| Worker
    API -->|"POST /api/ingest"| Worker
    Reprocess -->|"POST /api/links/:id/reprocess"| Worker

    SyncDO["SyncBackendDO<br/>(native SQLite)"]
    Worker["Hono Worker"]

    SyncDO -->|"fire-and-forget fetch()<br/>❌ no retry, no ack"| LinkDO
    Worker -->|"fire-and-forget fetch()"| LinkDO

    subgraph LinkDO["LinkProcessorDO"]
        direction TB
        LS["LiveStore Client<br/>(wasm SQLite + extensions)"]
        LS -->|"livePull: replay<br/>ENTIRE eventlog"| Sync2["SyncBackendDO"]
        LS -->|"rematerialize all<br/>SQLite tables"| State["Materialized State"]

        subgraph Chain["Sequential Processing Chain"]
            direction LR
            L1["link₁: fetch → AI → commit"] --> L2["link₂: waits..."] --> L3["link₃: waits..."]
        end

        State --> Chain
        Chain -->|"store.commit()"| LS
    end

    style Chain fill:#fee,stroke:#f66
    style LinkDO fill:#fff3e0
