{
  "name": "cloudstash",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --port 3000",
    "dev:infra": "bun run --parallel dev:emulate dev:tunnel dev:dashboard dev:raycast",
    "dev:emulate": "bunx emulate start --service google --seed emulate.config.yaml",
    "dev:make-admin": "wrangler d1 execute DB --local --command \"UPDATE user SET approved = 1, role = 'admin' WHERE email = 'admin@cloudstash.test'\"",
    "email:dev": "email dev -d src/cf-worker/email/templates -p 3001",
    "dev:tunnel": "bun scripts/telegram-tunnel.ts",
    "dev:raycast": "test -d local/raycast-extension || exit 0; npm --prefix local/raycast-extension run dev",
    "sync": "bash scripts/sync-repos.sh",
    "dev:dashboard": "localflare attach --no-open",
    "build": "vp build",
    "build:prod": "wrangler d1 migrations apply DB --remote && vp build",
    "preview": "vp preview",
    "deploy": "wrangler d1 migrations apply DB --remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio --config drizzle-studio.config.ts",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage --coverage.reporter=text --coverage.reportOnFailure",
    "test:e2e": "mkdir -p dist && vitest run --config vitest.e2e.config.ts",
    "cf-typegen": "wrangler types --no-include-runtime",
    "typecheck": "tsgo --noEmit",
    "check": "vp check && bun run check:effect",
    "check:effect": "effect-language-service diagnostics --project tsconfig.json --format pretty --strict --lspconfig '{\"allowedDuplicatedPackages\": [\"@livestore/utils\"]}'",
    "fix": "vp check --fix",
    "prepare": "effect-language-service patch",
    "clean:local-state": "rm -rf .wrangler/state/v3/cache .wrangler/state/v3/do .wrangler/state/v3/kv .wrangler/state/v3/workflows"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.136",
