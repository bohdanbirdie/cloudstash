  "packageManager": "bun@1.3.11",
  "cloudflare": {
    "bindings": {
      "GOOGLE_CLIENT_ID": {
        "description": "Google OAuth Client ID from [Google Cloud Console](https://console.cloud.google.com/apis/credentials)"
      },
      "GOOGLE_CLIENT_SECRET": {
        "description": "Google OAuth Client Secret"
      },
      "BETTER_AUTH_SECRET": {
        "description": "Random string (32+ chars). Generate with: openssl rand -hex 32"
      },
      "BETTER_AUTH_URL": {
        "description": "Full URL of your deployed Worker (e.g. https://cloudstash.your-subdomain.workers.dev)"
      },
      "RESEND_API_KEY": {
        "description": "API key from [Resend](https://resend.com) for approval emails"
      },
      "EMAIL_FROM": {
        "description": "Email sender address (e.g. YourApp <noreply@yourdomain.com>)"
      }
    }
  },
  "patchedDependencies": {
    "@livestore/common-cf@0.0.0-snapshot-6f52faf73b355b985b1289377e46eaed50f5acb6": "patches/@livestore%2Fcommon-cf@0.0.0-snapshot-6f52faf73b355b985b1289377e46eaed50f5acb6.patch",
